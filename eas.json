{
  "cli": {
    "version": "^18.0.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "APP_VARIANT": "development"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "distribution": "internal",
      "channel": "production",
      "env": {
        "APP_VARIANT": "production"
      },
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      }
    },
    "store": {
      "channel": "production",
      "env": {
        "APP_VARIANT": "production"
      },
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
