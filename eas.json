{
  "cli": {
    "version": "^18.0.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "APP_VARIANT": "development"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "developmentClient": false,
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "APP_VARIANT": "preview",
        "ANDROID_BUILD_ARCHS": "arm64-v8a"
      },
      "autoIncrement": false,
      "android": {
        "buildType": "apk"
      }
    },
    "release-apk-arm64": {
      "developmentClient": false,
      "distribution": "internal",
      "channel": "production",
      "env": {
        "APP_VARIANT": "production",
        "ANDROID_BUILD_ARCHS": "arm64-v8a"
      },
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      }
    },
    "release-apk-armv7": {
      "developmentClient": false,
      "distribution": "internal",
      "channel": "production",
      "env": {
        "APP_VARIANT": "production",
        "ANDROID_BUILD_ARCHS": "armeabi-v7a"
      },
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      }
    },
    "store": {
      "channel": "production",
      "env": {
        "APP_VARIANT": "production",
        "ANDROID_BUILD_ARCHS": "arm64-v8a,armeabi-v7a"
      },
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
