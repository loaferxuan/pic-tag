{
  "expo": {
    "name": "PicTag",
    "slug": "pic-tag",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pictag",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/6265028b-2b79-4538-89ed-f013d6cdbd2f"
    },
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#016BE5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pictag.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "需要访问相册以导入和管理照片",
        "NSCameraUsageDescription": "需要相机以拍摄照片",
        "NSMicrophoneUsageDescription": "录制视频时需要麦克风"
      }
    },
    "android": {
      "package": "com.pictag.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#016BE5"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow PicTag to read your photos for import/backfill matching."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "pgyer": {
        "appKey": "287f020da45bba8012d34b47bf7ae950"
      },
      "eas": {
        "projectId": "6265028b-2b79-4538-89ed-f013d6cdbd2f"
      }
    }
  }
}
